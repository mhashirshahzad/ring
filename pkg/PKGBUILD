# Maintainer: Your Name <bongopoyo@proton.me>
pkgname=ring
pkgver=0.1.0
pkgrel=1
pkgdesc="Ping-like utility written in Rust"
arch=('x86_64')
url="https://github.com/MHashirShahzad/ring"
license=('MIT')
depends=('glibc')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/MHashirShahzad/ring/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP') # replace with actual sha256sum of the tarball

build() {
    cd "$srcdir/ring-$pkgver"
    cargo build --release
}

package() {
    cd "$srcdir/ring-$pkgver"
    install -Dm755 target/release/ring "$pkgdir/usr/bin/ring"
    install -Dm644 README.md "$pkgdir/usr/share/doc/ring/README.md"
}
